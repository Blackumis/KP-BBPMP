# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bbpmp_presensi

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
ATTENDANCE_JWT_SECRET=123139019274719

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Base URL - IMPORTANT for production deployment!
# BASE_URL: URL where backend is hosted
# FRONTEND_URL: URL where frontend is hosted (used for QR code validation links in certificates)
# For local development:
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
# For production (example): 
# BASE_URL=https://presensi.bbpmpjateng.id
# FRONTEND_URL=https://presensi.bbpmpjateng.id
